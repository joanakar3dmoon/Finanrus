{
  "expo": {
    "name": "FINANRUS",
    "slug": "finanrus",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": { "backgroundColor": "#0D1117" },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.finanrus.app" },
    "android": {
      "package": "com.finanrus.app",
      "versionCode": 2,
      "adaptiveIcon": { "backgroundColor": "#0D1117" },
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE"]
    },
    "plugins": ["expo-build-properties"],
    "extra": { "eas": { "projectId": "9dfdfe73-7c35-443b-8a1d-74e9cc30c00c" } }
  }
}
